# Local demo only. Replace both values before starting Splunk.
# Splunk admin password (min 8 chars, including a digit)
SPLUNK_PASSWORD=changeme-Demo1

# HEC token used by the data seeder
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000

# Auth for the agent: none needed if Claude Code is logged in (Pro/Max).
# Optionally set ANTHROPIC_API_KEY=sk-ant-... to bill an API key instead.
# SOCKEYE_MODEL=sonnet

# Required by the hosted web container. Generate with:
# python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
SOCKEYE_WEB_API_KEY=replace-with-a-long-random-value
# Comma-separated trusted reverse-proxy IPs. Do not use * on a public network.
SOCKEYE_FORWARDED_ALLOW_IPS=127.0.0.1

# Required for hosted/container use. Local CLI use may instead use Claude Code login.
ANTHROPIC_API_KEY=

# Filled in by scripts/setup_splunk.sh after it creates the MCP bearer token
SPLUNK_MCP_URL=http://127.0.0.1:8089/services/mcp
SPLUNK_MCP_TOKEN=
