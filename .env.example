# Splunk admin password for the local Docker instance (min 8 chars, 1 digit)
SPLUNK_PASSWORD=changeme-Demo1

# HEC token used by the data seeder
SPLUNK_HEC_TOKEN=00000000-0000-0000-0000-000000000000

# Anthropic API key for the triage agent
ANTHROPIC_API_KEY=sk-ant-...

# Filled in by scripts/setup_splunk.sh after it creates the MCP bearer token
SPLUNK_MCP_URL=https://localhost:8089/services/mcp
SPLUNK_MCP_TOKEN=
